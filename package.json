{
    "name": "social-video-utility",
    "version": "1.1.0",
    "description": "Professional tool for downloading and viewing social media video content.",
    "main": "main.js",
    "homepage": "https://github.com/kaptanoguz/SocialVideoUtility",
    "scripts": {
        "start": "electron .",
        "package": "electron-builder --linux deb",
        "dist": "electron-builder",
        "dist:linux": "electron-builder --linux deb AppImage",
        "dist:win": "electron-builder --win portable",
        "dist:all": "electron-builder --linux deb AppImage --win portable"
    },
    "keywords": [
        "social",
        "video",
        "downloader",
        "electron",
        "utility"
    ],
    "author": {
        "name": "kaptanoguz",
        "email": "kaptanoguz@gmail.com"
    },
    "license": "MIT",
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    },
    "dependencies": {
        "python-shell": "^5.0.0"
    },
    "build": {
        "appId": "com.kaptanoguz.socialvideoutility",
        "productName": "Social Video Utility",
        "linux": {
            "target": [
                "deb",
                "AppImage"
            ],
            "category": "Network",
            "icon": "build/icon.png",
            "maintainer": "kaptanoguz <kaptanoguz@gmail.com>"
        },
        "win": {
            "target": [
                "portable"
            ],
            "icon": "build/icon.png"
        },
        "portable": {
            "artifactName": "SocialVideoUtility-${version}-portable.exe"
        },
        "deb": {
            "depends": [
                "python3",
                "python3-pip",
                "ffmpeg"
            ]
        },
        "files": [
            "**/*",
            "build/icon.png"
        ],
        "extraResources": [
            "backend",
            "build"
        ]
    }
}